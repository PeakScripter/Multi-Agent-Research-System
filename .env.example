# ── Required ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...          # Groq API key (console.groq.com)

# ── Speech (Sarvam AI) ────────────────────────────────────────────────────────
SARVAM_API_KEY=                # get from dashboard.sarvam.ai (optional — voice features)

# ── Vector DB (Qdrant) ────────────────────────────────────────────────────────
# Leave both empty to use local persistent mode (./qdrant_data)
QDRANT_URL=                    # e.g. https://xyz.us-east-1-0.aws.cloud.qdrant.io
QDRANT_API_KEY=                # Qdrant Cloud API key (only needed for cloud)
QDRANT_LOCAL_PATH=./qdrant_data

# ── Optional data sources ─────────────────────────────────────────────────────
YOUTUBE_API_KEY=               # Google Cloud → YouTube Data API v3 (transcript search)
SERPAPI_KEY=                   # serpapi.com (patent search)

# ── Model config ──────────────────────────────────────────────────────────────
MODELS_CONFIG_FILE=models_config.json
